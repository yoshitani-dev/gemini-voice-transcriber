@echo off
cd /d "%~dp0"

if "%~1"=="" (
    echo =======================================================
    echo   PC音声録音 ＆ 文字起こしツール
    echo =======================================================
    echo.
    echo   PCのシステム音声を録音し、AIが文字起こしします。
    echo.
    Gemini_CLI_Transcriber.exe
) else (
    echo =======================================================
    echo   ファイル文字起こしツール
    echo =======================================================
    echo.
    echo   ファイル: %~nx1
    echo.
    Gemini_CLI_Transcriber.exe "%~1"
)
echo.
pause
