@echo off
chcp 65001 >nul
cd /d "%~dp0"

if "%~1"=="" (
    echo =======================================================
    echo   音声文字起こしツール
    echo =======================================================
    echo.
    echo   PC音声をリアルタイムで録音して文字起こしします。
    echo.
    python audio_transcriber.py
) else (
    echo =======================================================
    echo   ファイル文字起こしツール
    echo =======================================================
    echo.
    echo   処理するファイル: %~nx1
    echo.
    python audio_transcriber.py "%~1"
)

echo.
pause
